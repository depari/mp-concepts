node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
package-lock.json

# ----- Vite 빌드 결과물 -----
dist/
dist-ssr/
build/
.vite/

# ----- Svelte -----
.svelte-kit/
*.svelte-kit/

# ----- OS 생성 파일 -----
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ----- 에디터 / IDE -----
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.orig

# ----- 환경 변수 -----
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local

# ----- 임시 / 캐시 -----
*.log
*.cache
.cache/
.temp/
tmp/
temp/

# ----- 테스트 커버리지 -----
coverage/
.nyc_output/

# ----- Android / Gradle -----
.gradle/
local.properties
*.apk
*.aab
